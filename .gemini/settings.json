{
  "mcpServers": {
    "fpl_server": {
      "command": "poetry",
      "args": [
        "run",
        "python",
        "-m",
        "fpl_agent.cli_mcp_server"
      ],
      "cwd": "fpl-agent",
      "env": {
        "MCP_SERVER_URL": "${env:MCP_SERVER_URL}",
        "MCP_API_KEY": "${env:MCP_API_KEY}",
        "GOOGLE_CLOUD_PROJECT": "${env:GOOGLE_CLOUD_PROJECT}"
      },
      "timeout": 30000
    }
  }
}